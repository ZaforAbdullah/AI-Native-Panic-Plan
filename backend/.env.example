CORS_ORIGINS=localhost:3000
# ── AI Provider ───────────────────────────────────────────────────────────────
# Set to "gemini" for production or "lmstudio" for local development
AI_PROVIDER=gemini

# ── Gemini (production) ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# ── LM Studio (local dev) ─────────────────────────────────────────────────────
# Start LM Studio → Local Server tab → Start Server
# Load any instruction-following model (e.g. Mistral, Llama 3, Phi-3)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
# Set this to the model identifier shown in LM Studio's server panel
LMSTUDIO_MODEL=google/gemma-4-e4b
# Must match the embedding model identifier loaded in LM Studio (see /v1/models)
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# ── Auth & Database ───────────────────────────────────────────────────────────
SECRET_KEY=supersecretjwtkeychangeme
DATABASE_URL=postgresql://user:password@host.com:5432/database

# ── Supabase pgvector (required — vector store backend) ───────────────────────
# Apply supabase/migrations/20260629000000_vector_store.sql before first use.
SUPABASE_URL=https://project_id.supabase.co/rest/v1/
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# ── LangFuse (optional — tracing/observability) ───────────────────────────────
# Get keys at: https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com